{
  "claude": {
    "command": [
      "claude",
      "--disable-slash-commands",
      "--print",
      "--output-format",
      "json",
      "--no-session-persistence",
      "--tools",
      ""
    ],
    "response_format": "claude-json",
    "budget_flag": "--max-budget-usd"
  },
  "codex": {
    "command": [
      "codex",
      "exec",
      "--ephemeral",
      "--ignore-user-config",
      "--sandbox",
      "read-only",
      "--skip-git-repo-check",
      "--json"
    ],
    "response_format": "codex-jsonl"
  }
}
